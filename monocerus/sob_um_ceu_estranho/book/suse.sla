        <PAGEOBJECT XPOS="919.212598425197" YPOS="1448.45669291339" OwnPage="4" ItemID="997238443" PTYPE="4" WIDTH="421.098862642171" HEIGHT="92.8853893263342" FRTYPE="0" CLIPEDIT="0" ROT="90" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L421.099 0 L421.099 92.8854 L0 92.8854 L0 0 Z" copath="M0 0 L421.099 0 L421.099 92.8854 L0 92.8854 L0 0 Z" gXpos="919.212598425197" gYpos="1448.45669291339" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
